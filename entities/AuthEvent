{
  "name": "AuthEvent",
  "type": "object",
  "properties": {
    "event_type": {
      "type": "string",
      "enum": [
        "signup",
        "login"
      ]
    },
    "user_email": {
      "type": "string"
    },
    "user_name": {
      "type": "string"
    },
    "provider": {
      "type": "string",
      "enum": [
        "email",
        "google",
        "unknown"
      ],
      "default": "unknown"
    },
    "event_time": {
      "type": "string"
    }
  },
  "required": [
    "event_type"
  ]
}
