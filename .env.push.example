# Copy to .env.push and fill values for the push sender service
PUSH_SERVER_PORT=8787
PUSH_SERVER_API_KEY=

# VAPID keys for Web Push
WEB_PUSH_PUBLIC_KEY=
WEB_PUSH_PRIVATE_KEY=
WEB_PUSH_SUBJECT=mailto:you@example.com

# Firebase Admin credentials (use one option below)
# Option A: path to service-account JSON file
FIREBASE_SERVICE_ACCOUNT_FILE=

# Option B: raw JSON string of service-account credentials
FIREBASE_SERVICE_ACCOUNT_JSON=

# Optional explicit project id
FIREBASE_PROJECT_ID=
